# Django
SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,armin2080.de,www.armin2080.de

# Lightweight local storage
DB_NAME=/var/lib/portfolio/db.sqlite3
STATIC_ROOT=/var/lib/portfolio/staticfiles
MEDIA_ROOT=/var/lib/portfolio/media

# Gunicorn
GUNICORN_BIND=0.0.0.0:80
GUNICORN_WORKERS=1
GUNICORN_TIMEOUT=30

# Contact form email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
